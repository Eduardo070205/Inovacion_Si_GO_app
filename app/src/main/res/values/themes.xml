<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Inovacion_2026" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/verde_tenue</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="colorSecondaryContainer">#DCFCE7</item>
        <item name="colorOnSecondaryContainer">#16A34A</item>
    </style>

    <style name="Theme.Inovacion_2026.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Inovacion_2026.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.Inovacion_2026.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
