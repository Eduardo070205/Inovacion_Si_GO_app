<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        android:background="?attr/selectableItemBackground"
        android:contentDescription="Ver detalle de planta"
        android:importantForAccessibility="yes">

        <!-- NOMBRE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:importantForAccessibility="no">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="18sp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/txt_planta_nombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Tomate"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <!-- UMBRAL (badge azul) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:importantForAccessibility="no">

            <TextView
                android:id="@+id/txt_planta_umbral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_min"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="3000"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <!-- TEMP MIN (badge azul) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:gravity="center"
            android:importantForAccessibility="no">

            <TextView
                android:id="@+id/txt_planta_tmp_min"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_min"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="15°"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <!-- TEMP MAX (badge rojo) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:gravity="center"
            android:importantForAccessibility="no">

            <TextView
                android:id="@+id/txt_planta_tmp_max"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_max"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="30°"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <!-- BOTÓN ELIMINAR -->
        <TextView
            android:id="@+id/btn_planta_eliminar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="🗑️"
            android:textSize="18sp"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Eliminar planta" />

    </LinearLayout>
</androidx.cardview.widget.CardView>